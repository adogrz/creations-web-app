{
  "name": "my-project",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.9",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/engines",
      "prisma",
      "sharp",
      "esbuild"
    ]
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "format:check": "prettier --check .",
    "format:write": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "check:catalog": "tsx scripts/check-catalog-navigation.ts",
    "check:proxy": "tsx scripts/check-proxy.ts",
    "check:uploads": "tsx scripts/check-image-upload-validation.ts",
    "check:r2-cleanup": "node scripts/check-r2-orphan-cleanup.mjs",
    "check:critical": "tsx scripts/check-critical-contracts.ts && pnpm check:uploads && pnpm check:proxy && pnpm check:r2-cleanup",
    "check:integration": "NODE_ENV=test INTEGRATION_TEST_DATABASE=1 tsx scripts/check-catalog-integration.ts",
    "check:docker": "node scripts/check-docker-image.mjs",
    "r2:cleanup": "node scripts/r2-orphan-cleanup.mjs",
    "r2:cleanup:delete": "node scripts/r2-orphan-cleanup.mjs --delete",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1078.0",
    "@base-ui/react": "^1.5.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.16.0",
    "next": "16.2.6",
    "next-themes": "^0.4.6",
    "pg": "^8.22.0",
    "react": "^19",
    "react-dom": "^19",
    "shadcn": "^4.8.0",
    "sharp": "^0.35.3",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.3.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^9.39.4",
    "@next/eslint-plugin-next": "^16.2.10",
    "@tailwindcss/postcss": "^4.2.0",
    "@types/node": "^24",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@typescript-eslint/parser": "^8.63.0",
    "dotenv": "^17.4.2",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.10",
    "postcss": "^8.5",
    "prettier": "^3.9.4",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "prisma": "^7.8.0",
    "tailwindcss": "^4.2.0",
    "tsx": "^4.22.4",
    "typescript": "5.7.3"
  }
}
